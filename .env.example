# OrthoLineage Guardian — environment template.
# Copy to `.env` (gitignored) and adjust. NEVER commit real tokens.

# DataHub GMS / API endpoint.
# Local quickstart publishes GMS on host port 8090 (see scripts/datahub_up.sh — GMS is
# remapped off the default 8080 to avoid host port conflicts).
DATAHUB_GMS_URL=http://localhost:8090

# DataHub access token.
# The local OSS quickstart runs with metadata-service auth DISABLED, so this can be left
# empty. For a secured DataHub instance, put a Personal Access Token here.
DATAHUB_GMS_TOKEN=

# Host port GMS is published on (consumed by scripts/datahub_up.sh). Override if 8090 is
# taken on your machine.
DATAHUB_MAPPED_GMS_PORT=8090

# --- LLM layer (Batch 5) ---------------------------------------------------------------
# The LLM only improves the prose of explanations and remediation drafts; it is NEVER
# required for correctness. With no key present, everything runs in deterministic template
# mode (or force it with `--no-llm`). NEVER commit a real key.
ANTHROPIC_API_KEY=
# Pinned Claude model id used when a key is present (a current Claude model).
GUARDIAN_MODEL=claude-opus-4-8
